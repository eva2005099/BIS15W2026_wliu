leaflet(spiders) %>%
addTiles() %>%
addCircleMarkers(
lng=~longitude,
lat=~latitude,
radius=2,
stroke=FALSE,
fillOpacity = 0.7
) %>%
addScaleBar(position="bottomleft") %>%
fitBounds(lng1=lon_min,lat1=lat_min,
lng2=lon_max,lat2=lat_max)
